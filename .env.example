# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# NextAuth — https://authjs.dev
AUTH_SECRET="replace-with-random-string"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic link — Nodemailer (optional)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM=""

# AI providers — Anthropic required for core scan pipeline
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL=""

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"

# Stripe (optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (optional)
RESEND_API_KEY=""

# Inngest (optional — sync with dashboard when enabling scheduled rescans)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
