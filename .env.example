# Database (PostgreSQL)
# Supabase: use the "Transaction" pooler URI for DATABASE_URL (port 6543, include ?pgbouncer=true if shown).
# Use the "Direct connection" URI for DIRECT_URL (port 5432, host db.<project-ref>.supabase.co).
# Local dev: set DIRECT_URL to the same connection string as DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# NextAuth — https://authjs.dev
AUTH_SECRET="replace-with-random-string"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic link — Nodemailer (optional)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM=""

# AI providers — scans & analysis default to Claude unless ANALYSIS_LLM_PROVIDER is set
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""

# Agents: claude | deepseek | kimi (moonshot). Defaults to claude.
AGENT_LLM_PROVIDER="claude"

# Optional: override backend for scan scoring, synthesis, plan, chat, deep dive (defaults to AGENT_LLM_PROVIDER then claude)
ANALYSIS_LLM_PROVIDER=""

# DeepSeek (OpenAI-compatible — default https://api.deepseek.com/v1)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL=""
DEEPSEEK_MODEL="deepseek-chat"

# Moonshot Kimi (OpenAI-compatible — default https://api.moonshot.cn/v1 — override if using global endpoint)
MOONSHOT_API_KEY=""
MOONSHOT_BASE_URL=""
MOONSHOT_MODEL="moonshot-v1-8k"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL=""

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"

# Stripe (optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (optional)
RESEND_API_KEY=""

# Inngest (optional — sync with dashboard when enabling scheduled rescans)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
